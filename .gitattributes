# Normalize source files as LF text across platforms.
* text=auto
.gitattributes text eol=lf
.editorconfig text eol=lf
.gitignore text eol=lf
.dockerignore text eol=lf
Dockerfile text eol=lf
LICENSE text eol=lf
*.conf text eol=lf
*.htaccess text eol=lf

*.sh text eol=lf
*.py text eol=lf
*.vue text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.svg text eol=lf
docs/LICENSE text eol=lf

# Keep binary assets untouched.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.db binary
*.sqlite binary
*.sqlite3 binary
*.woff binary
*.woff2 binary
